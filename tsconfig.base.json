{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@creativeclaw/core": ["packages/core/src/index.ts"],
      "@creativeclaw/tool-registry": ["packages/tool-registry/src/index.ts"],
      "@creativeclaw/action-executor": ["packages/action-executor/src/index.ts"],
      "@creativeclaw/memory": ["packages/memory/src/index.ts"],
      "@creativeclaw/connectors-adobe": ["packages/connectors-adobe/src/index.ts"]
    },
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node"]
  }
}
